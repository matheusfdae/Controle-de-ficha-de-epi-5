# Copie para .env e preencha com os dados do seu Supabase (cloud ou self-hosted)
# e do seu app Clerk. Usado tanto por "npm run dev" quanto por
# "docker compose build" (docker compose lê o .env automaticamente para
# preencher os build args).

VITE_SUPABASE_URL="http://localhost:8000"
VITE_SUPABASE_PUBLISHABLE_KEY="cole-aqui-a-ANON_KEY-gerada-pelo-generate-keys.sh"
VITE_SUPABASE_PROJECT_ID="self-hosted"

# Publishable Key do app Clerk (dashboard Clerk -> API Keys). Pública, ok
# ir no bundle do frontend. NUNCA coloque a Secret Key (sk_...) aqui — essa
# vai só como secret das Edge Functions (ver SELF_HOSTING.md).
VITE_CLERK_PUBLISHABLE_KEY="pk_..."

# Porta local em que o container do frontend fica exposto (docker-compose.yml)
APP_PORT=3000

# ---------------------------------------------------------------------------
# Secrets de BACKEND (Edge Functions) — NÃO são lidos pelo Vite/frontend e
# NUNCA devem levar o prefixo VITE_. Ficam no .env da supabase-project
# (self-hosted) ou nos Function Secrets do projeto (cloud), não neste
# arquivo/no bundle do app. Documentados aqui só para referência:
#
# CLERK_SECRET_KEY             sk_... (dashboard Clerk -> API Keys)
# CLERK_WEBHOOK_SECRET         whsec_... (dashboard Clerk -> Webhooks)
# INVITE_ALLOWED_EMAIL_DOMAIN  domínio aceito em admin-invite-user
#                               (padrão no código: grupo5estrelas.com.br)
# APP_PUBLIC_URL                URL pública do frontend, usada como
#                               redirect_url do convite
#                               (padrão no código: https://app.grupo5estrelas.com.br)
# ---------------------------------------------------------------------------
